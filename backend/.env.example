# Server Port
PORT=3000

# MongoDB URI connection string (use mongodb+srv://... for MongoDB Atlas)
MONGODB_URI=mongodb://localhost:27017/truong-thanh-stationery

# JWT Secret and Expiration configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Gemini API Key for AI operations (optional)
GEMINI_API_KEY=your_gemini_api_key_here

# Google Sheets WebApp URL for syncing orders (optional)
GOOGLE_SHEET_WEBAPP_URL=https://script.google.com/macros/s/xxxx/exec

# Cloudinary credentials for avatar uploads (optional)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_secret

# Allowed CORS Frontend origins (comma separated if multiple, e.g. https://your-domain.vercel.app)
FRONTEND_URL=http://localhost:5173
